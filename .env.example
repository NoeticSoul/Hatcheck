# Hatcheck environment configuration.
# Copy to .env and adjust. All secrets come from environment variables only
# (see SECURITY.md) -- never commit a real .env file.

# ---------------------------------------------------------------------------
# Core server
# ---------------------------------------------------------------------------

# development | test | production
NODE_ENV=development

# HTTP port the API server listens on.
PORT=3000

# Public base URL of the app. Defaults to http://localhost:$PORT if unset.
# Set this when running behind a reverse proxy or a non-localhost hostname.
#APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# sqlite (standalone mode, default) | postgres (server mode)
HATCHECK_DB=sqlite

# Required when HATCHECK_DB=postgres. Use the same POSTGRES_PASSWORD as below.
# With docker-compose.yml this is set for you inside the compose file.
#DATABASE_URL=postgres://hatcheck:change-me@localhost:5432/hatcheck

# SQLite database file location (standalone mode only).
HATCHECK_SQLITE_PATH=./data/hatcheck.db

# ---------------------------------------------------------------------------
# Sessions
# ---------------------------------------------------------------------------

# Session lifetime in hours.
SESSION_TTL_HOURS=12

# ---------------------------------------------------------------------------
# Reverse proxy
# ---------------------------------------------------------------------------

# Set to true ONLY when a trusted reverse proxy (nginx, Caddy, Traefik...)
# sits in front of Hatcheck and appends the client address to
# X-Forwarded-For. When false (default), that header is ignored for rate
# limiting and audit records because clients can forge it.
#HATCHECK_TRUST_PROXY=false

# ---------------------------------------------------------------------------
# OIDC single sign-on (optional)
# ---------------------------------------------------------------------------
# Leave all of these unset to run with local accounts only. If you set one of
# ISSUER / CLIENT_ID / CLIENT_SECRET you must set all three.

#OIDC_ISSUER=https://idp.example.test/realms/hatcheck
#OIDC_CLIENT_ID=hatcheck
#OIDC_CLIENT_SECRET=change-me
# Defaults to $APP_URL/api/v1/auth/oidc/callback if unset.
#OIDC_REDIRECT_URI=http://localhost:3000/api/v1/auth/oidc/callback

# ---------------------------------------------------------------------------
# AI adapter (optional, off by default)
# ---------------------------------------------------------------------------

# anthropic | openai | ollama -- leave unset to disable all AI features.
#HATCHECK_AI_PROVIDER=

# ---------------------------------------------------------------------------
# Seeding
# ---------------------------------------------------------------------------

# Initial admin password for `bun run seed`. If unset, the seed script
# generates a random one and prints it once.
#HATCHECK_SEED_ADMIN_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Docker Compose (server mode)
# ---------------------------------------------------------------------------

# Password for the bundled PostgreSQL container. Required by
# docker-compose.yml; compose fails fast if this is unset.
#POSTGRES_PASSWORD=change-me
