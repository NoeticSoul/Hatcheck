{
  "name": "hatcheck",
  "version": "0.0.1",
  "private": true,
  "description": "Self-hosted IT management platform: assets, locations, imaging pipeline, knowledge base, doc studio.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20",
    "bun": ">=1.3"
  },
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:web": "vite src/web",
    "build": "vite build src/web",
    "start": "bun src/server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "compile": "bun scripts/compile.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.sqlite.config.ts && drizzle-kit generate --config=drizzle.pg.config.ts",
    "seed": "bun src/db/seed.ts",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.5.1",
    "@node-rs/argon2": "^2.0.2",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "lucide-react": "^1.25.0",
    "openid-client": "^6.8.4",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "@node-rs/argon2",
    "esbuild",
    "@tailwindcss/oxide"
  ]
}
